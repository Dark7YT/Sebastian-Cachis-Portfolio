---
import { Icon } from 'astro-icon/components';
import type { Dictionary } from '@lib/i18n';

interface Props {
  t: Dictionary['footer'];
}
const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-border)] bg-[color:var(--color-bg-base)]">
  <div
    class="container-wide flex flex-col items-start justify-between gap-6 py-10 sm:flex-row sm:items-center sm:gap-4"
  >
    <div class="flex flex-col gap-1">
      <span class="font-serif text-lg italic text-[color:var(--color-text-primary)]">
        Sebastian<span class="text-[color:var(--color-accent)]">.</span>
      </span>
      <span class="font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-[color:var(--color-text-muted)]">
        © {year} · <span data-i18n="footer.rights">{t.rights}</span>
      </span>
    </div>

    <div class="flex flex-wrap items-center gap-4 font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-[color:var(--color-text-muted)]">
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 transition hover:text-[color:var(--color-accent)]"
      >
        <Icon name="simple-icons:astro" class="size-3.5" aria-hidden="true" />
        <span data-i18n="footer.builtWith">{t.builtWith}</span>
      </a>
      <a
        href="https://github.com/Dark7YT/Sebastian-Cachis-Portfolio"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 transition hover:text-[color:var(--color-accent)]"
      >
        <Icon name="simple-icons:github" class="size-3.5" aria-hidden="true" />
        <span data-i18n="footer.repo">{t.repo}</span>
      </a>
    </div>
  </div>
</footer>
