---
import { Icon } from 'astro-icon/components';
import type { Dictionary, Locale } from '@lib/i18n';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  locale: Locale;
  t: Dictionary;
  path: string;
}
const { locale, t, path } = Astro.props;

const sections: { id: string; label: string }[] = [
  { id: 'about', label: t.nav.about },
  { id: 'experience', label: t.nav.experience },
  { id: 'projects', label: t.nav.projects },
  { id: 'stack', label: t.nav.stack },
  { id: 'contact', label: t.nav.contact },
];
---

<header
  class="sticky top-0 z-40 border-b border-[color:var(--color-border)] bg-[color:var(--color-base)]/80 backdrop-blur-md"
  data-site-header
>
  <div class="container-wide flex h-16 items-center justify-between gap-4 sm:h-20">
    <a
      href={`/${locale}/`}
      class="font-serif text-lg tracking-tight text-[color:var(--color-text-primary)] transition hover:text-[color:var(--color-accent)]"
    >
      <span class="italic">Sebastian</span>
      <span class="text-[color:var(--color-accent)]">.</span>
    </a>

    <nav aria-label="primary" class="hidden items-center gap-8 lg:flex">
      {
        sections.map((s) => (
          <a
            href={`#${s.id}`}
            class="font-mono text-xs uppercase tracking-[0.2em] text-[color:var(--color-text-secondary)] transition hover:text-[color:var(--color-accent)]"
          >
            {s.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <LanguageToggle locale={locale} path={path} t={t.toggles.language} />
      <ThemeToggle t={t.toggles.theme} />
      <button
        type="button"
        data-mobile-menu-open
        class="inline-flex size-10 items-center justify-center rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] lg:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
        aria-label={t.nav.menu}
        aria-controls="mobile-nav"
        aria-expanded="false"
      >
        <Icon name="lucide:menu" class="size-5" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div
    id="mobile-nav"
    data-mobile-menu
    class="fixed inset-0 z-50 hidden bg-[color:var(--color-base)]/95 backdrop-blur-lg lg:hidden"
    aria-hidden="true"
  >
    <div class="container-wide flex h-16 items-center justify-between sm:h-20">
      <span class="font-serif text-lg italic text-[color:var(--color-text-primary)]">Sebastian<span class="text-[color:var(--color-accent)]">.</span></span>
      <button
        type="button"
        data-mobile-menu-close
        class="inline-flex size-10 items-center justify-center rounded-full border border-[color:var(--color-border)] text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
        aria-label={t.nav.close}
      >
        <Icon name="lucide:x" class="size-5" aria-hidden="true" />
      </button>
    </div>
    <nav class="container-wide mt-8 flex flex-col gap-6">
      {
        sections.map((s) => (
          <a
            href={`#${s.id}`}
            data-mobile-menu-link
            class="font-serif text-4xl tracking-tight text-[color:var(--color-text-primary)] transition hover:text-[color:var(--color-accent)]"
          >
            {s.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const openBtn = document.querySelector<HTMLButtonElement>('[data-mobile-menu-open]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-mobile-menu-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-menu-link]');

  function setOpen(open: boolean) {
    if (!menu || !openBtn) return;
    menu.classList.toggle('hidden', !open);
    menu.setAttribute('aria-hidden', String(!open));
    openBtn.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  openBtn?.addEventListener('click', () => setOpen(true));
  closeBtn?.addEventListener('click', () => setOpen(false));
  links.forEach((l) => l.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
