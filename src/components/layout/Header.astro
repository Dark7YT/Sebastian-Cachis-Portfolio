---
import { Icon } from 'astro-icon/components';
import type { Dictionary, Locale } from '@lib/i18n';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  locale: Locale;
  t: Dictionary;
  path: string;
}
const { locale, t, path } = Astro.props;

const sections: { id: string; label: string }[] = [
  { id: 'about', label: t.nav.about },
  { id: 'experience', label: t.nav.experience },
  { id: 'projects', label: t.nav.projects },
  { id: 'stack', label: t.nav.stack },
  { id: 'contact', label: t.nav.contact },
];
---

<header
  class="sticky top-0 z-40 border-b border-[color:var(--color-border)] bg-[color:var(--color-bg-base)]/80 backdrop-blur-md"
  data-site-header
  transition:persist
>
  <div class="container-wide flex h-16 items-center justify-between gap-4 sm:h-20">
    <a
      href={`/${locale}/`}
      class="font-serif text-lg tracking-tight text-[color:var(--color-text-primary)] transition hover:text-[color:var(--color-accent)]"
    >
      <span class="italic">Sebastian</span>
      <span class="text-[color:var(--color-accent)]">.</span>
    </a>

    <nav aria-label="primary" class="hidden items-center gap-8 lg:flex">
      {
        sections.map((s) => (
          <a
            href={`#${s.id}`}
            class="font-mono text-xs uppercase tracking-[0.2em] text-[color:var(--color-text-secondary)] transition hover:text-[color:var(--color-accent)]"
          >
            {s.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <LanguageToggle locale={locale} path={path} t={t.toggles.language} />
      <ThemeToggle t={t.toggles.theme} />
      <button
        type="button"
        data-mobile-menu-open
        class="inline-flex size-10 items-center justify-center rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)] text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] lg:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
        aria-label={t.nav.menu}
        aria-controls="mobile-nav"
        aria-expanded="false"
      >
        <Icon name="lucide:menu" class="size-5" aria-hidden="true" />
      </button>
    </div>
  </div>
</header>

<!-- Overlay backdrop -->
<div
  data-mobile-overlay
  class="fixed inset-0 z-50 bg-black/40 opacity-0 backdrop-blur-sm transition-opacity duration-300 lg:hidden"
  style="pointer-events: none;"
  aria-hidden="true"
></div>

<!-- Right-side drawer -->
<aside
  id="mobile-nav"
  data-mobile-menu
  class="fixed top-0 right-0 z-50 flex h-full w-80 max-w-[85vw] flex-col border-l border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)] shadow-2xl lg:hidden"
  style="transform: translateX(100%); transition: transform 350ms cubic-bezier(0.4, 0, 0.2, 1);"
  aria-hidden="true"
  aria-label={t.nav.menu}
>
  <!-- Drawer header -->
  <div class="flex h-16 items-center justify-between border-b border-[color:var(--color-border)] px-6 sm:h-20">
    <span class="font-serif text-base italic text-[color:var(--color-text-primary)]">
      Sebastian<span class="text-[color:var(--color-accent)]">.</span>
    </span>
    <button
      type="button"
      data-mobile-menu-close
      class="inline-flex size-9 items-center justify-center rounded-full border border-[color:var(--color-border)] text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
      aria-label={t.nav.close}
    >
      <Icon name="lucide:x" class="size-4" aria-hidden="true" />
    </button>
  </div>

  <!-- Drawer nav links -->
  <nav class="flex flex-1 flex-col justify-center gap-2 px-6 py-8">
    {
      sections.map((s, i) => (
        <a
          href={`#${s.id}`}
          data-mobile-menu-link
          class="group flex items-baseline gap-4 py-3 text-[color:var(--color-text-primary)] transition hover:text-[color:var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
        >
          <span class="w-6 shrink-0 font-mono text-[0.65rem] text-[color:var(--color-text-muted)] transition group-hover:text-[color:var(--color-accent)]">
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="font-serif text-2xl tracking-tight">{s.label}</span>
        </a>
      ))
    }
  </nav>

  <!-- Drawer footer -->
  <div class="border-t border-[color:var(--color-border)] px-6 py-5">
    <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-[color:var(--color-text-muted)]">
      Sebastian Cachis · Lima, Perú
    </p>
  </div>
</aside>

<script>
  function initMobileMenu() {
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    const overlay = document.querySelector<HTMLElement>('[data-mobile-overlay]');
    const openBtn = document.querySelector<HTMLButtonElement>('[data-mobile-menu-open]');
    const closeBtn = document.querySelector<HTMLButtonElement>('[data-mobile-menu-close]');
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-menu-link]');

    if (!menu || !openBtn) return;

    function setOpen(open: boolean) {
      if (!menu || !overlay || !openBtn) return;

      if (open) {
        menu.style.transform = 'translateX(0)';
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'auto';
        menu.setAttribute('aria-hidden', 'false');
        openBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        // Focus first link for accessibility
        const firstLink = menu.querySelector<HTMLAnchorElement>('[data-mobile-menu-link]');
        firstLink?.focus();
      } else {
        menu.style.transform = 'translateX(100%)';
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
        menu.setAttribute('aria-hidden', 'true');
        openBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        openBtn.focus();
      }
    }

    openBtn.addEventListener('click', () => setOpen(true));
    closeBtn?.addEventListener('click', () => setOpen(false));
    overlay.addEventListener('click', () => setOpen(false));
    links.forEach((l) => l.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>
