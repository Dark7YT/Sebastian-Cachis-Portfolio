---
// No props — locale is managed entirely client-side by i18n-client.ts
---

<button
  type="button"
  data-lang-toggle
  class="lang-toggle inline-flex h-10 items-center gap-1.5 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)] px-3 font-mono text-xs uppercase tracking-widest text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
  data-i18n-label="toggles.language.label"
  aria-label="Cambiar idioma"
>
  <span data-lang-current class="font-semibold text-[color:var(--color-accent)]">ES</span>
  <span class="text-[color:var(--color-text-muted)]">/</span>
  <span data-lang-other>EN</span>
</button>

<style>
  .lang-toggle:active [data-lang-current] {
    transform: translateY(-2px) scale(0.9);
    opacity: 0.6;
    transition: transform 150ms ease, opacity 150ms ease;
  }
  .lang-toggle:active [data-lang-other] {
    color: var(--color-accent);
    transition: color 150ms ease;
  }
</style>

<script>
  import { getLocale, setLocale } from '@scripts/i18n-client';

  function syncToggles() {
    const locale = getLocale();
    const other = locale === 'es' ? 'en' : 'es';
    document.querySelectorAll<HTMLElement>('[data-lang-toggle]').forEach((btn) => {
      const cur = btn.querySelector<HTMLElement>('[data-lang-current]');
      const oth = btn.querySelector<HTMLElement>('[data-lang-other]');
      if (cur) cur.textContent = locale.toUpperCase();
      if (oth) oth.textContent = other.toUpperCase();
    });
  }

  function init() {
    syncToggles();
    document.querySelectorAll<HTMLButtonElement>('[data-lang-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = getLocale() === 'es' ? 'en' : 'es';
        setLocale(next);
        syncToggles();
      });
    });
  }

  document.addEventListener('astro:after-swap', init);
  document.addEventListener('astro:page-load', init);
</script>
