---
import { Icon } from 'astro-icon/components';
---

<button
  type="button"
  data-lang-toggle
  class="lang-toggle inline-flex h-10 items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)] px-3.5 font-mono text-xs uppercase tracking-widest transition hover:border-[color:var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
  data-i18n-label="toggles.language.label"
  aria-label="Cambiar idioma"
>
  <Icon name="lucide:languages" class="size-3.5 shrink-0 text-[color:var(--color-text-muted)]" aria-hidden="true" />
  <span data-lang-current class="font-semibold text-[color:var(--color-accent)]">ES</span>
  <span class="text-[color:var(--color-border)]">/</span>
  <span data-lang-other class="text-[color:var(--color-text-muted)]">EN</span>
</button>

<script>
  import { getLocale, setLocale } from '@scripts/i18n-client';

  function syncToggles() {
    const locale = getLocale();
    const other = locale === 'es' ? 'en' : 'es';
    document.querySelectorAll<HTMLElement>('[data-lang-toggle]').forEach((btn) => {
      const cur = btn.querySelector<HTMLElement>('[data-lang-current]');
      const oth = btn.querySelector<HTMLElement>('[data-lang-other]');
      if (cur) cur.textContent = locale.toUpperCase();
      if (oth) oth.textContent = other.toUpperCase();
    });
  }

  function init() {
    syncToggles();
    document.querySelectorAll<HTMLButtonElement>('[data-lang-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = getLocale() === 'es' ? 'en' : 'es';
        setLocale(next);
        syncToggles();
      });
    });
  }

  document.addEventListener('astro:after-swap', init);
  document.addEventListener('astro:page-load', init);
</script>
