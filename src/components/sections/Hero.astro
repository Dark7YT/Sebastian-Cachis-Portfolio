---
import { Icon } from 'astro-icon/components';
import type { Dictionary } from '@lib/i18n';

interface Props {
  t: Dictionary['hero'];
}
const { t } = Astro.props;
---

<section id="hero" class="relative overflow-hidden">
  <div class="hero-backdrop" aria-hidden="true"></div>

  <div
    class="container-wide relative flex min-h-[calc(100svh-4rem)] flex-col justify-center py-24 sm:min-h-[calc(100svh-5rem)] sm:py-28 lg:py-40"
  >
    <p
      class="reveal font-mono text-xs uppercase tracking-[0.3em] text-[color:var(--color-accent)] sm:text-sm"
      style="--reveal-delay: 0ms"
    >
      {t.eyebrow}
    </p>

    <h1
      class="reveal mt-6 font-serif text-[length:var(--text-hero)] leading-[var(--text-hero--line-height)] tracking-tight text-[color:var(--color-text-primary)]"
      style="--reveal-delay: 80ms"
    >
      {t.name}
    </h1>

    <p
      class="reveal mt-6 max-w-3xl font-serif text-[length:var(--text-heading)] leading-[var(--text-heading--line-height)] text-[color:var(--color-text-secondary)] italic sm:mt-8"
      style="--reveal-delay: 160ms"
    >
      {t.tagline}
    </p>

    <div
      class="reveal mt-10 flex items-center gap-3 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)]/60 px-4 py-2 text-sm text-[color:var(--color-text-secondary)] backdrop-blur-sm sm:mt-12 sm:w-fit sm:max-w-full"
      style="--reveal-delay: 240ms"
    >
      <span
        class="inline-flex size-2 rounded-full bg-[color:var(--color-accent)] shadow-[0_0_0_4px_var(--color-accent-muted)]"
        aria-hidden="true"
      ></span>
      <span class="font-mono text-xs tracking-widest uppercase">{t.metric}</span>
    </div>

    <div
      class="reveal mt-10 flex flex-wrap gap-3 sm:mt-14"
      style="--reveal-delay: 320ms"
    >
      <a
        href="#projects"
        class="inline-flex items-center gap-2 rounded-full bg-[color:var(--color-accent)] px-6 py-3 font-mono text-xs font-medium uppercase tracking-widest text-[color:var(--color-bg-base)] transition hover:bg-[color:var(--color-accent-hover)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
      >
        {t.ctaProjects}
        <Icon name="lucide:arrow-down" class="size-4" aria-hidden="true" />
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-transparent px-6 py-3 font-mono text-xs font-medium uppercase tracking-widest text-[color:var(--color-text-primary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
      >
        {t.ctaContact}
        <Icon name="lucide:arrow-right" class="size-4" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>

<style>
  .hero-backdrop {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 80% 60% at 20% 10%,
        var(--color-accent-muted) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 60% 40% at 90% 90%,
        var(--color-accent-muted) 0%,
        transparent 70%
      );
    pointer-events: none;
    z-index: 0;
  }

  .hero-backdrop::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.15;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, black 0%, transparent 80%);
  }

  .reveal {
    opacity: 0;
    transform: translateY(1rem);
    animation: hero-reveal 900ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
