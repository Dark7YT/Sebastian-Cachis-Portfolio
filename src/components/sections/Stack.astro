---
import { Icon } from 'astro-icon/components';
import type { Dictionary } from '@lib/i18n';
import { stackGroups } from '@lib/stack';

interface Props {
  t: Dictionary['stack'];
}
const { t } = Astro.props;
---

<section
  id="stack"
  class="relative border-t border-[color:var(--color-border)] bg-[color:var(--color-bg-base)]"
>
  <div class="container-wide section-padding">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-[color:var(--color-accent)]">
        {t.heading}
      </p>
      <h2
        class="mt-6 font-serif text-[length:var(--text-display)] leading-[var(--text-display--line-height)] tracking-tight text-[color:var(--color-text-primary)]"
      >
        {t.intro}
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-8 sm:mt-20 md:grid-cols-2 lg:grid-cols-4">
      {
        stackGroups.map((group) => (
          <div data-reveal class="flex flex-col gap-4">
            <h3 class="font-mono text-[0.6875rem] uppercase tracking-[0.3em] text-[color:var(--color-text-muted)]">
              {t.groups[group.id]}
            </h3>
            <ul class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)] px-3 py-1.5 font-mono text-xs text-[color:var(--color-text-secondary)] transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]">
                  {item.icon && <Icon name={item.icon} class="size-3.5" aria-hidden="true" />}
                  <span>{item.name}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
