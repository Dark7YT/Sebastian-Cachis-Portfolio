---
import { Icon } from 'astro-icon/components';
import type { Dictionary } from '@lib/i18n';

interface Props {
  t: Dictionary['training'];
}
const { t } = Astro.props;
---

<section
  id="training"
  class="relative border-t border-[color:var(--color-border)] bg-[color:var(--color-bg-base)]"
>
  <div class="container-wide section-padding">
    <div class="max-w-3xl">
      <p
        data-i18n="training.heading"
        class="font-mono text-xs uppercase tracking-[0.3em] text-[color:var(--color-accent)]"
      >
        {t.heading}
      </p>
      <h2
        data-i18n="training.intro"
        class="mt-6 font-serif text-[length:var(--text-display)] leading-[var(--text-display--line-height)] tracking-tight text-[color:var(--color-text-primary)]"
      >
        {t.intro}
      </h2>
    </div>

    <ul class="mt-14 grid grid-cols-1 gap-4 sm:mt-20 sm:gap-5 md:grid-cols-2">
      {
        t.items.map((item, i) => (
          <li
            data-reveal
            class="group flex h-full flex-col gap-3 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-bg-surface)] p-6 transition hover:border-[color:var(--color-accent)] hover:shadow-[var(--shadow-accent)] sm:p-7"
          >
            <div class="flex items-center justify-between gap-3">
              <span class="font-mono text-[0.6875rem] uppercase tracking-[0.3em] text-[color:var(--color-text-muted)]">
                {String(i + 1).padStart(2, '0')}
              </span>
              <Icon
                name="lucide:sparkles"
                class="size-4 text-[color:var(--color-accent)] opacity-60 transition group-hover:opacity-100"
                aria-hidden="true"
              />
            </div>
            <h3
              data-i18n={`training.items.${i}.title`}
              class="font-serif text-xl tracking-tight text-[color:var(--color-text-primary)] sm:text-[1.375rem]"
            >
              {item.title}
            </h3>
            <p
              data-i18n={`training.items.${i}.description`}
              class="text-sm leading-relaxed text-[color:var(--color-text-secondary)]"
            >
              {item.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
