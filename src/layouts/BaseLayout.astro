---
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@styles/global.css';

import { ClientRouter } from 'astro:transitions';
import { buildSeo } from '@lib/seo';
import type { SeoProps } from '@lib/seo';

type Props = SeoProps;

const seo = buildSeo(Astro.props);
---

<!doctype html>
<html lang="es" data-theme="dark" data-lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />

    <!-- Theme: prevent FOUC by reading localStorage before first paint -->
    <script>
      import '@scripts/theme-init.ts';
    </script>

    <!-- Locale: set data-lang on <html> immediately so CSS locale blocks apply before body renders -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem('lang');
          if (l !== 'es' && l !== 'en') {
            var c = document.cookie.match(/(?:^|;\s*)lang=(es|en)/);
            l = c ? c[1] : (navigator.language || '').startsWith('es') ? 'es' : 'en';
          }
          document.documentElement.dataset.lang = l;
          document.documentElement.lang = l;
        } catch (_) {}
      })();
    </script>

    <!-- i18n client: applies text translations and wires language toggle -->
    <script>
      import '@scripts/i18n-client.ts';
    </script>

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="author" content={seo.author} />
    <meta name="generator" content={Astro.generator} />

    {seo.noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={seo.canonical} />
    <link rel="alternate" hreflang="es" href={seo.canonical} />
    <link rel="alternate" hreflang="en" href={seo.canonical} />
    <link rel="alternate" hreflang="x-default" href={seo.canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" sizes="any" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={seo.twitter} />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />

    <ClientRouter />
  </head>
  <body>
    <!-- Page loader — visible on first paint, dismissed on window load -->
    <div id="page-loader" aria-hidden="true">
      <div class="pl-logo">
        <span class="pl-bracket">&lt;</span>
        <span class="pl-name">Sebastian</span>
        <span class="pl-bracket"> /&gt;</span>
      </div>
      <div class="pl-track">
        <div class="pl-fill"></div>
      </div>
    </div>

    <script is:inline>
      (function () {
        function dismiss() {
          var el = document.getElementById('page-loader');
          if (el) el.classList.add('pl-done');
        }
        window.addEventListener('load', function () {
          setTimeout(dismiss, 250);
        });
        // Failsafe: never block for more than 3s
        setTimeout(dismiss, 3000);
      })();
    </script>

    <slot />
  </body>
</html>

<style is:global>
  #page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #0a0a0b;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #page-loader.pl-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .pl-logo {
    display: flex;
    align-items: baseline;
    gap: 2px;
    animation: pl-enter 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .pl-bracket {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.8rem;
    font-weight: 700;
    color: #f5b841;
    line-height: 1;
  }

  .pl-name {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.6rem;
    font-style: italic;
    color: #f5f5f7;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pl-track {
    width: 100px;
    height: 1.5px;
    background: #26262c;
    border-radius: 1px;
    overflow: hidden;
  }

  .pl-fill {
    height: 100%;
    width: 0%;
    background: #f5b841;
    border-radius: 1px;
    animation: pl-fill 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: 0.1s;
  }

  @keyframes pl-enter {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pl-fill {
    to { width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pl-logo { animation: none; }
    .pl-fill  { animation: none; width: 100%; }
  }
</style>
