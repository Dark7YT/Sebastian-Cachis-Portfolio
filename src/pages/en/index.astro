---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import { useTranslations } from '@lib/i18n';

const locale = 'en';
const t = useTranslations(locale);
const path = '/en/';
---

<BaseLayout locale={locale} path={path}>
  <Header locale={locale} t={t} path={path} />
  <main class="container-content section-padding">
    <p class="font-mono text-sm tracking-widest text-[color:var(--color-accent)] uppercase">
      {t.hero.eyebrow}
    </p>
    <h1
      class="mt-4 text-[length:var(--text-hero)] leading-[var(--text-hero--line-height)] tracking-tight"
    >
      {t.hero.name}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[color:var(--color-text-secondary)]">
      {t.hero.tagline}
    </p>
  </main>
</BaseLayout>
