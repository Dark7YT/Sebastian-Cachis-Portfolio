---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Hero from '@components/sections/Hero.astro';
import About from '@components/sections/About.astro';
import Experience from '@components/sections/Experience.astro';
import Projects from '@components/sections/Projects.astro';
import GsapReveal from '@components/islands/GsapReveal.astro';
import { useTranslations } from '@lib/i18n';

const locale = 'es';
const t = useTranslations(locale);
const path = '/es/';
---

<BaseLayout locale={locale} path={path}>
  <Header locale={locale} t={t} path={path} />
  <main>
    <Hero t={t.hero} />
    <About t={t.about} />
    <Experience t={t.experience} locale={locale} />
    <Projects t={t.projects} locale={locale} />
  </main>
  <GsapReveal />
</BaseLayout>
